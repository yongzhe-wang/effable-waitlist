# Supabase — public (browser) keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase — server-only secret. NEVER ship this to the browser.
# Required for /api/waitlist to insert under service-role (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public site origin for canonical metadata + OG tags
NEXT_PUBLIC_SITE_URL=http://localhost:5000
